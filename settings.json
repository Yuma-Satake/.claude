{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "AWS_REGION": "us-east-1",
    "BASH_MAX_OUTPUT_LENGTH": "15000",
    "CLAUDE_CODE_FORK_SUBAGENT": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git clean:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-sonnet-5",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/herdr-agent-state.sh session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.5 /System/Library/Sounds/Hero.aiff"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/check-knowledge-review-pending.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/set-knowledge-review-flag.sh",
            "if": "Bash(git commit *)"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__claude-in-chrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Chrome MCPツール使用時は必ずmcp-chromeスキル（~/.claude/skills/mcp-chrome/SKILL.md）を確認してから操作する\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__slack__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Slack MCPツール使用時は必ずmcp-slackスキル（~/.claude/skills/mcp-slack/SKILL.md）を確認してから操作する\"}}'"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/inject-agent-use.sh"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Planモード後の実行原則: 可能な限りユーザとのやり取りを避け、実行を完了まで継続する。タスクを分解し、依存関係を整理して並列実行可能な箇所は複数のサブエージェントで並行して進める。クラウドサービスの設定確認・変更が必要な場合はCLIやブラウザ操作で自力対応する。\"}}'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "datadog@claude-plugins-official": false,
    "discord@claude-plugins-official": false,
    "conference-organizing-knowledge-skill@conference-organizing-knowledge-skill": false,
    "cloudflare@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "conference-organizing-knowledge-skill": {
      "source": {
        "source": "github",
        "repo": "fec-nagoya-org/conference-organizing-knowledge-skill"
      }
    }
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "advisorModel": "claude-opus-4-8",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": false,
  "voiceEnabled": true
}
