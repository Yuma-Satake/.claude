{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(git reset:*)",
      "Bash(git checkout:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__claude-in-chrome__.*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Chrome MCPツール使用中。chrome-mcpスキル（~/.claude/skills/chrome-mcp/SKILL.md）と、操作対象サイトに対応する references/ 配下のナレッジファイル（note.md / oauth.md / google-sheets.md / fortee.md 等）を確認してから操作すること。\"}}'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./.claude/plans",
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true
}
